# ============================================================
# Root .dockerignore — applies when building from repo root
# ============================================================

# Version control
.git
.github
.gitignore

# Python artefacts
__pycache__
*.pyc
*.pyo
*.pyd
*.pdb
.pytest_cache
.mypy_cache
.ruff_cache
*.egg-info
dist/
build/

# Node / Next.js
.next
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (NEVER bake secrets into images)
.env
.env.*
*.env

# Documentation
*.md
*.rst
LICENSE
CHANGELOG

# Test artefacts
tests/
e2e/
coverage/
htmlcov/
.coverage
*.lcov
playwright-report/

# CI/CD
.github/

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Docker
docker-compose*.yml
Dockerfile*
