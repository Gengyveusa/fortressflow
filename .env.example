# ============================================================
# FortressFlow Production Environment
# Copy this file to .env.prod and fill in all values.
# NEVER commit .env.prod to version control.
#
# Generate secrets:
#   openssl rand -hex 32   →  32-byte (64 hex char) key
#   openssl rand -hex 16   →  16-byte (32 hex char) key
# ============================================================

# ------------------------------------------------------------
# Core Database
# ------------------------------------------------------------
POSTGRES_PASSWORD=<strong-password>

# ------------------------------------------------------------
# Message Broker
# ------------------------------------------------------------
RABBITMQ_USER=fortressflow
RABBITMQ_PASS=<strong-password>

# ------------------------------------------------------------
# Application Secrets
# ------------------------------------------------------------
# 64-character random string: openssl rand -hex 32
SECRET_KEY=<random-64-char-string>
# 32-character random string: openssl rand -hex 16
UNSUBSCRIBE_HMAC_KEY=<random-32-char-string>

# ------------------------------------------------------------
# Environment
# ------------------------------------------------------------
ENVIRONMENT=production

# ------------------------------------------------------------
# Error Tracking
# ------------------------------------------------------------
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>

# ------------------------------------------------------------
# HubSpot CRM
# ------------------------------------------------------------
HUBSPOT_API_KEY=
HUBSPOT_APP_ID=
HUBSPOT_BREEZE_ENABLED=true

# ------------------------------------------------------------
# ZoomInfo
# ------------------------------------------------------------
ZOOMINFO_CLIENT_ID=
ZOOMINFO_CLIENT_SECRET=
ZOOMINFO_API_KEY=
ZOOMINFO_COPILOT_ENABLED=true

# ------------------------------------------------------------
# Apollo.io
# ------------------------------------------------------------
APOLLO_API_KEY=
APOLLO_AI_ENABLED=true

# ------------------------------------------------------------
# Twilio (SMS / Voice)
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ------------------------------------------------------------
# AWS SES (Email Sending)
# ------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SES_FROM_EMAIL=hello@gengyveusa.com
SES_CONFIGURATION_SET=fortressflow-tracking
SENDING_SUBDOMAIN=mail.gengyveusa.com

# ------------------------------------------------------------
# IMAP (Reply Detection)
# ------------------------------------------------------------
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=

# ------------------------------------------------------------
# LinkedIn OAuth
# ------------------------------------------------------------
LINKEDIN_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_SECRET=

# ------------------------------------------------------------
# Grafana
# ------------------------------------------------------------
# At least 12 characters, mix of upper/lower/digits/symbols
GRAFANA_PASSWORD=<strong-password>

# ------------------------------------------------------------
# NextAuth.js
# ------------------------------------------------------------
NEXTAUTH_URL=https://app.gengyveusa.com
# 64-character random string: openssl rand -hex 32
NEXTAUTH_SECRET=<random-64-char-string>

# ------------------------------------------------------------
# Docker / CI — set automatically in CI, optional locally
# ------------------------------------------------------------
# GITHUB_REPOSITORY=fortressflow/fortressflow
# IMAGE_TAG=latest

# ------------------------------------------------------------
# Phase 7: AI Chatbot Assistant
# ------------------------------------------------------------
# Groq (primary LLM — fast + cheap). Get key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# OpenAI (fallback LLM). Get key at https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Chat configuration
CHAT_MAX_TOKENS=1024
CHAT_RATE_LIMIT_PER_MINUTE=30
CHAT_HISTORY_RETENTION_DAYS=90
