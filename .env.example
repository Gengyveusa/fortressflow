# Database
POSTGRES_PASSWORD=fortressflow_dev
DATABASE_URL=postgresql+asyncpg://fortressflow:fortressflow_dev@localhost:5432/fortressflow

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://fortressflow:fortressflow_dev@localhost:5672/
RABBITMQ_USER=fortressflow
RABBITMQ_PASS=fortressflow_dev

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=dev-secret-key-change-in-production-use-openssl-rand-hex-32
UNSUBSCRIBE_HMAC_KEY=dev-hmac-key-change-in-production-use-openssl-rand-hex-32

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-nextauth-secret-change-in-production

# Integrations (optional)
HUBSPOT_API_KEY=
ZOOMINFO_CLIENT_ID=
ZOOMINFO_CLIENT_SECRET=
APOLLO_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS SES
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SES_FROM_EMAIL=

# Monitoring (optional)
SENTRY_DSN=
GRAFANA_PASSWORD=admin

# Environment
